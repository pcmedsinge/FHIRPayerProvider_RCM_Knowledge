{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FhirServer": {
    "BaseUrl": "http://localhost:8082/fhir"
  },
  "BulkExport": {
    "OutputDirectory": "export-output",
    "MaxResourcesPerFile": 1000,
    "DefaultResourceTypes": "Patient,ExplanationOfBenefit,Coverage,Encounter,MedicationRequest,Condition,Procedure,Observation"
  }
}
